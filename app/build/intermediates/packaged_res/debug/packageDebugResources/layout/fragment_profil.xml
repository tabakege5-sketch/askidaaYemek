<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/profilResmi"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="32dp"
        app:shapeAppearanceOverlay="@style/CircleImageView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/profilKartiView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/profilResmi">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/kullaniciEmailTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="email@adres.com"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="10dp" />

            <TextView
                android:id="@+id/kullaniciRolTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rol: MUSTERI" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Switch
        android:id="@+id/koyuModSvitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Karanlık Mod"
        app:layout_constraintTop_toBottomOf="@id/profilKartiView"
        tools:ignore="UseSwitchCompatOrMaterialXml" />

    <Button
        android:id="@+id/cikisYapButtonn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Çıkış Yap"
        app:layout_constraintTop_toBottomOf="@id/koyuModSvitch" />

</androidx.constraintlayout.widget.ConstraintLayout>