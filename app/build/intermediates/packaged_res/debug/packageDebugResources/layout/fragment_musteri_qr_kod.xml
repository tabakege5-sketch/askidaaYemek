<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/musteriQrKodOkutmaToolBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/outline_arrow_back_24"
        app:title="QR Kodum" />

    <TextView
        android:id="@+id/askıdanQrAlmaTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="QR Kodunuzu Gösterin"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/musteriQrKodOkutmaToolBar" />

    <ImageView
        android:id="@+id/qrKodOkuyucusu"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/ic_launcher_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/askıdanQrAlmaTextView" />

    <LinearLayout
        android:id="@+id/kategoriLinearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/qrKodOkuyucusu">

        <TextView
            android:id="@+id/urununIsmi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ürün İsmi:"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/isimSoyIsimTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ad - Soyad:"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/emailTextView"
            android:layout_width="match_parent"
            android:layout_marginTop="8dp"
            android:text="e-mail:"
            android:textSize="16sp"
            android:layout_height="match_parent">
        </TextView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>