<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/girisLoginFragment">

    <fragment
        android:id="@+id/girisLoginFragment"
        android:name="com.example.askidaayemek.view.girisLoginFragment"
        android:label="Giriş Yap"
        tools:layout="@layout/fragment_giris_login" >
        <action
            android:id="@+id/action_girisLoginFragment_to_detayFragment"
            app:destination="@id/detayFragment" />
    </fragment>

    <fragment
        android:id="@+id/detayFragment"
        android:name="com.example.askidaayemek.view.detayFragment"
        android:label="Detaylar"
        tools:layout="@layout/fragment_detay" >
        <action
            android:id="@+id/action_detayFragment_to_haritaFragment"
            app:destination="@id/haritaFragment" />
    </fragment>

    <fragment
        android:id="@+id/haritaFragment"
        android:name="com.example.askidaayemek.view.haritaFragment"
        android:label="Harita"
        tools:layout="@layout/fragment_harita" >
        <action
            android:id="@+id/action_haritaFragment_to_ilanEkleFragment2"
            app:destination="@id/ilanEkleFragment2" />
    </fragment>

    <fragment
        android:id="@+id/ilanEkleFragment2"
        android:name="com.example.askidaayemek.view.ilanEkleFragment"
        android:label="İlan Ekle"
        tools:layout="@layout/fragment_ilan_ekle">
        <action
            android:id="@+id/action_ilanEkleFragment2_to_detayFragment"
            app:destination="@id/detayFragment" />
        <action
            android:id="@+id/action_ilanEkleFragment2_to_haritaFragment"
            app:destination="@id/haritaFragment" />
    </fragment>
    <fragment
        android:id="@+id/parolaFragment"
        android:name="com.example.askidaayemek.view.parolaFragment"
        android:label="fragment_parola"
        tools:layout="@layout/fragment_parola" />
    <fragment
        android:id="@+id/urunEkleFragment"
        android:name="com.example.askidaayemek.view.urunEkleFragment"
        android:label="fragment_urun_ekle"
        tools:layout="@layout/fragment_urun_ekle" />
    <fragment
        android:id="@+id/kayitOlFragment"
        android:name="com.example.askidaayemek.view.kayitOlFragment"
        android:label="kayitOlFragment" />
    <fragment
        android:id="@+id/urunPaylasanFragment"
        android:name="com.example.askidaayemek.view.urunPaylasanFragment"
        android:label="fragment_urun_paylasan"
        tools:layout="@layout/fragment_urun_paylasan" />

</navigation>