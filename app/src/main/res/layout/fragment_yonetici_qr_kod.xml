<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/geriGitImageView"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/outline_arrow_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/yoneticiPaneliTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Yönetici Paneli"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/geriGitImageView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/geriGitImageView" />

    <ImageView
        android:id="@+id/qrKodImageView"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="150dp"
        android:padding="10dp"
        android:background="@drawable/ic_launcher_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/yoneticiPaneliTextView" />

    <LinearLayout
        android:id="@+id/bilgiLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/qrKodImageView">

        <TextView
            android:id="@+id/musterininAdSoyad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AD / SOYAD"
            android:textSize="18sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/talepBilgileriTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ürün Bilgileri"
            android:textSize="16sp" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonTeslimEt"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="20dp"
        android:text="İŞLEMİ TAMAMLA"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="32dp"
        android:textStyle="bold"
        android:layout_marginTop="80dp"
        android:text="QR KODU OKUTUN"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/yoneticiPaneliTextView" />

</androidx.constraintlayout.widget.ConstraintLayout>