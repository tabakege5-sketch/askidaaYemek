<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/geriGitImageView"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/outline_arrow_back_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/yoneticiPaneliTextView"
        android:layout_width="260dp"
        android:layout_height="50dp"
        android:layout_marginStart="80dp"
        android:layout_marginTop="4dp"
        android:textStyle="bold"
        android:text="Yönetici Paneli"
        android:textSize="32sp"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/qrKodOkutView"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/yoneticiPaneliTextView" />

    <LinearLayout
        android:id="@+id/bilgiLayout"
        android:layout_width="374dp"
        android:layout_height="166dp"
        android:layout_marginTop="44dp"
        android:orientation="vertical"
        android:padding="30dp"
        app:layout_constraintTop_toBottomOf="@id/qrKodOkutView"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="-4dp">

        <TextView
            android:id="@+id/musterininAdSoyad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ad - Soyad"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/talepBilgileriTextView"
            android:layout_width="146dp"
            android:layout_height="39dp"
            android:text="Talep Bilgileri" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonTeslimEt"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="20dp"
        android:text="TESLİM ET"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/bilgiLayout"
        app:layout_constraintVertical_bias="0.936"
        tools:layout_editor_absoluteX="46dp" />

</androidx.constraintlayout.widget.ConstraintLayout>