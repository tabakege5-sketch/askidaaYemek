<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageButton
                android:id="@+id/tarihGeriButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/outline_arrow_back_24"
                android:contentDescription="Geri Dön" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Tarih Seçiniz:"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <CalendarView
            android:id="@+id/takvimView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Tam Saati Seçiniz:"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TimePicker
            android:id="@+id/tamSaatTimePicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:timePickerMode="spinner" />

        <EditText
            android:id="@+id/bilgiEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="Yorum Yap:"
            android:inputType="textMultiLine"
            android:minHeight="80dp"
            android:padding="12dp" />

        <Button
            android:id="@+id/secimiKaydetButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="30dp"
            android:text="KAYDET"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>