<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/yoneticiBaslik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Yönetici Paneli Erişimi"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <EditText
        android:id="@+id/yonetininIsmiSoyIsmiEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="YÖNETİCİNİN İSMİ/SOY İSMİ "
        android:padding="16dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/yoneticiBaslik"/>

    <EditText
        android:id="@+id/yoneticiEmailEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Yönetici E-posta"
        android:inputType="textEmailAddress"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/yonetininIsmiSoyIsmiEditText"/>

    <EditText
        android:id="@+id/yoneticiSifreEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Şifre"
        android:inputType="textPassword"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/yoneticiEmailEditText"/>

    <EditText
        android:id="@+id/yetkiKoduEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Özel Kod Gönderildi"
        android:inputType="numberPassword"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/yoneticiSifreEditText"/>

    <Button
        android:id="@+id/yoneticiKayitBttonn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="YÖNETİCİ OLARAK KAYDOL"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/yetkiKoduEditText"/>

</androidx.constraintlayout.widget.ConstraintLayout>